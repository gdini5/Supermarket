<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Erro — Marketplace</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <main class="container" style="display:flex; justify-content:center; align-items:center; min-height:80vh;">
    <div class="card" style="text-align:center; padding:3rem; max-width:480px; width:100%;">
      <h1 style="font-size:4rem; margin:0;">⚠️</h1>
      <h2 style="margin:1rem 0;"><%= message || 'Ocorreu um erro.' %></h2>
      <a href="/" class="btn btn-primary">Voltar ao início</a>
    </div>
  </main>
</body>
</html>