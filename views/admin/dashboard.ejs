<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Admin — Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  <main class="container">
    <h1 class="page-title">Dashboard Admin</h1>

    <% if (pendingSupermarkets > 0) { %>
      <div class="alert alert-info" style="margin-bottom:1.5rem">
        ⚠ Tens <strong><%= pendingSupermarkets %></strong> supermercado(s) a aguardar aprovação.
        <a href="/admin/supermarkets" style="font-weight:700;margin-left:.5rem">Aprovar agora →</a>
      </div>
    <% } %>

    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-icon">👥</span>
        <span class="stat-number"><%= totalUsers %></span>
        <span class="stat-label">Utilizadores</span>
      </div>
      <div class="stat-card">
        <span class="stat-icon">🏪</span>
        <span class="stat-number"><%= activeSupermarkets %></span>
        <span class="stat-label">Supermercados Ativos</span>
      </div>
      <div class="stat-card">
        <span class="stat-icon">📦</span>
        <span class="stat-number"><%= totalOrders %></span>
        <span class="stat-label">Total de Encomendas</span>
      </div>
      <div class="stat-card stat-card--warning">
        <span class="stat-icon">⏳</span>
        <span class="stat-number"><%= pendingSupermarkets %></span>
        <span class="stat-label">Pendentes de Aprovação</span>
        <% if (pendingSupermarkets > 0) { %>
          <a href="/admin/supermarkets" class="btn btn-warning btn-sm" style="margin-top:.5rem">Ver agora</a>
        <% } %>
      </div>
    </div>

    <div class="quick-links">
      <h2>Ações rápidas</h2>
      <a href="/admin/supermarkets" class="btn btn-primary">Gerir Supermercados</a>
      <a href="/admin/users"        class="btn btn-secondary">Gerir Utilizadores</a>
      <a href="/admin/categories"   class="btn btn-secondary">Gerir Categorias</a>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
