<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Utilizadores — Marketplace</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  <main class="container">
    <h1 class="page-title">Utilizadores</h1>

    <% if (users.length === 0) { %>
      <p class="empty-state">Nenhum utilizador registado ainda.</p>
    <% } else { %>
      <table class="table">
        <thead>
          <tr><th>Nome</th><th>Email</th><th>Tipo</th><th>Estado</th><th>Registado em</th><th>Ações</th></tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
            <tr>
              <td><%= u.name %></td>
              <td><%= u.email %></td>
              <td><span class="badge badge--neutral"><%= u.role %></span></td>
              <td>
                <span class="badge <%= u.active ? 'badge--success' : 'badge--danger' %>">
                  <%= u.active ? 'Ativo' : 'Inativo' %>
                </span>
              </td>
              <td><%= u.createdAt.toLocaleDateString('pt-PT') %></td>
              <td class="actions">
                <form action="/admin/users/<%= u._id %>/toggle" method="POST" style="display:inline">
                  <button class="btn btn-sm <%= u.active ? 'btn-warning' : 'btn-success' %>">
                    <%= u.active ? 'Desativar' : 'Ativar' %>
                  </button>
                </form>
                <form action="/admin/users/<%= u._id %>/delete" method="POST" style="display:inline"
                      onsubmit="return confirm('Eliminar o utilizador \'<%= u.name %>\'? Esta ação é irreversível.')">
                  <button class="btn btn-sm btn-danger">Eliminar</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
