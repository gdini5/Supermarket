<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Loja — Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  <main class="container">
    <h1 class="page-title">Loja</h1>

    <% if (error === 'supermercado_diferente') { %>
      <div class="alert alert-error" style="margin-bottom:1rem">
        ⚠ Só podes encomendar de um supermercado de cada vez. Finaliza ou limpa o carrinho primeiro.
      </div>
    <% } %>
    <% if (error === 'sem_stock') { %>
      <div class="alert alert-error" style="margin-bottom:1rem">⚠ Produto sem stock disponível.</div>
    <% } %>

    <!-- Filtros -->
    <form action="/orders/shop" method="GET" class="search-form" style="margin-bottom:1.5rem">
      <input type="text" name="search" placeholder="Pesquisar produto..." value="<%= search %>">
      <select name="category">
        <option value="">Todas as categorias</option>
        <% categories.forEach(c => { %>
          <option value="<%= c.name %>" <%= category === c.name ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
      </select>
      <select name="supermarketId">
        <option value="">Todos os supermercados</option>
        <% supermarkets.forEach(s => { %>
          <option value="<%= s._id %>" <%= supermarketId === s._id.toString() ? 'selected' : '' %>><%= s.name %></option>
        <% }) %>
      </select>
      <select name="sort">
        <option value="">Ordenar por...</option>
        <option value="price_asc"  <%= sort === 'price_asc'  ? 'selected' : '' %>>Preço ↑</option>
        <option value="price_desc" <%= sort === 'price_desc' ? 'selected' : '' %>>Preço ↓</option>
      </select>
      <button type="submit" class="btn btn-secondary">Filtrar</button>
      <% if (search || category || supermarketId || sort) { %>
        <a href="/orders/shop" class="btn btn-secondary">Limpar</a>
      <% } %>
    </form>

    <!-- Carrinho rápido -->
    <% if (cart.items && cart.items.length > 0) { %>
      <div class="card" style="margin-bottom:1.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;padding:1rem 1.25rem">
        <span style="color:var(--text-2);font-size:.9rem">
          🛒 <strong><%= cart.items.reduce((a,i) => a + i.quantity, 0) %></strong> item(s) no carrinho
        </span>
        <a href="/orders/cart" class="btn btn-primary btn-sm">Ver carrinho</a>
      </div>
    <% } %>

    <!-- Aviso de comparação quando há produtos do mesmo nome -->
    <% 
      const nameGroups = {};
      products.forEach(p => {
        const key = p.name.toLowerCase().trim();
        if (!nameGroups[key]) nameGroups[key] = [];
        nameGroups[key].push(p);
      });
      const comparables = Object.values(nameGroups).filter(g => g.length > 1);
    %>
    <% if (comparables.length > 0 && !supermarketId) { %>
      <div class="card" style="margin-bottom:1.5rem;padding:1rem 1.25rem">
        <p style="font-size:.875rem;font-weight:600;margin-bottom:.75rem;color:var(--text-2)">
          💡 Produtos disponíveis em vários supermercados — compara preços:
        </p>
        <% comparables.slice(0,3).forEach(group => { %>
          <div style="margin-bottom:.75rem">
            <p style="font-size:.85rem;font-weight:600;margin-bottom:.35rem"><%= group[0].name %></p>
            <div style="display:flex;flex-wrap:wrap;gap:.5rem">
              <% group.sort((a,b) => a.price - b.price).forEach((p, i) => { %>
                <span class="badge <%= i === 0 ? 'badge--success' : 'badge--neutral' %>"
                  style="font-size:.8rem">
                  <%= p.supermarketId?.name || '?' %> —
                  <strong><%= p.price.toFixed(2) %> €/<%= p.priceUnit || 'un.' %></strong>
                  <%= i === 0 ? '✓ mais barato' : '' %>
                </span>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- Produtos -->
    <% if (products.length === 0) { %>
      <p class="empty-state">Nenhum produto disponível com os filtros selecionados.</p>
    <% } else { %>
      <div class="product-grid">
        <% products.forEach(p => { %>
          <div class="product-card">
            <div class="product-card__img">
              <img src="/images/uploads/<%= p.image %>" alt="<%= p.name %>"
                onerror="this.src='/images/uploads/default-product.png'">
            </div>
            <div class="product-card__body">
              <span class="badge badge--neutral" style="align-self:flex-start;font-size:.7rem"><%= p.category %></span>
              <strong class="product-card__name"><%= p.name %></strong>
              <% if (p.supermarketId) { %>
                <span style="font-size:.75rem;color:var(--text-3)">🏪 <%= p.supermarketId.name %></span>
              <% } %>
              <div class="product-card__footer">
                <strong class="product-card__price">
                  <%= p.price.toFixed(2) %> €/<%= p.priceUnit || 'un.' %>
                </strong>
                <span style="font-size:.75rem;color:var(--text-3)"><%= p.stock %> un.</span>
              </div>
              <% if (currentUser) { %>
                <form action="/orders/cart/add/<%= p._id %>" method="POST" style="margin-top:.4rem">
                  <button class="btn btn-primary btn-sm btn-block">Adicionar ao carrinho</button>
                </form>
              <% } else { %>
                <a href="/auth/login" class="btn btn-secondary btn-sm btn-block" style="margin-top:.4rem;text-align:center">
                  Login para comprar
                </a>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
