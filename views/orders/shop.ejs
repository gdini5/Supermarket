<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Loja — Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  <main class="container">
    <h1 class="page-title">Loja</h1>

    <% if (error === 'supermercado_diferente') { %>
      <div class="alert alert-error">
        ⚠ Só podes encomendar de um supermercado de cada vez. Finaliza ou limpa o carrinho primeiro.
      </div>
    <% } %>
    <% if (error === 'sem_stock') { %>
      <div class="alert alert-error">⚠ Produto sem stock disponível.</div>
    <% } %>

    <!-- Filtros -->
    <form action="/orders/shop" method="GET" class="search-form" style="margin-bottom:1.5rem">
      <input type="text" name="search" placeholder="Pesquisar produto..." value="<%= search %>">
      <select name="category">
        <option value="">Todas as categorias</option>
        <% categories.forEach(c => { %>
          <option value="<%= c %>" <%= category === c ? 'selected' : '' %>><%= c %></option>
        <% }) %>
      </select>
      <select name="supermarketId">
        <option value="">Todos os supermercados</option>
        <% supermarkets.forEach(s => { %>
          <option value="<%= s._id %>" <%= supermarketId === s._id.toString() ? 'selected' : '' %>><%= s.name %></option>
        <% }) %>
      </select>
      <button type="submit" class="btn btn-secondary">Filtrar</button>
      <% if (search || category || supermarketId) { %>
        <a href="/orders/shop" class="btn btn-secondary">Limpar</a>
      <% } %>
    </form>

    <!-- Carrinho rápido -->
    <% if (cart.items && cart.items.length > 0) { %>
      <div class="card" style="margin-bottom:1.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;padding:1rem 1.25rem">
        <span style="color:var(--text-2);font-size:.9rem">
          🛒 <strong><%= cart.items.reduce((a, i) => a + i.quantity, 0) %></strong> item(s) no carrinho
        </span>
        <a href="/orders/cart" class="btn btn-primary btn-sm">Ver carrinho</a>
      </div>
    <% } %>

    <!-- Produtos -->
    <% if (products.length === 0) { %>
      <p class="empty-state">Nenhum produto disponível com os filtros selecionados.</p>
    <% } else { %>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1.25rem">
        <% products.forEach(p => { %>
          <div class="card" style="padding:0;overflow:hidden;display:flex;flex-direction:column">
            <img src="/images/uploads/<%= p.image %>"
              alt="<%= p.name %>"
              style="width:100%;height:140px;object-fit:cover"
              onerror="this.src='/images/uploads/default-product.png'">
            <div style="padding:.9rem;flex:1;display:flex;flex-direction:column;gap:.35rem">
              <span class="badge badge--neutral" style="align-self:flex-start;font-size:.7rem"><%= p.category %></span>
              <strong style="font-size:.9rem;line-height:1.3"><%= p.name %></strong>
              <% if (p.supermarketId) { %>
                <span style="font-size:.75rem;color:var(--text-3)">🏪 <%= p.supermarketId.name %></span>
              <% } %>
              <div style="display:flex;justify-content:space-between;align-items:center;margin-top:auto;padding-top:.5rem">
                <strong style="color:var(--cyan);font-size:1rem"><%= p.price.toFixed(2) %> €</strong>
                <span style="font-size:.75rem;color:var(--text-3)"><%= p.stock %> un.</span>
              </div>
              <% if (currentUser) { %>
                <form action="/orders/cart/add/<%= p._id %>" method="POST" style="margin-top:.35rem">
                  <button class="btn btn-primary btn-sm btn-block">Adicionar ao carrinho</button>
                </form>
              <% } else { %>
                <a href="/auth/login" class="btn btn-secondary btn-sm btn-block" style="margin-top:.35rem">Login para comprar</a>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
