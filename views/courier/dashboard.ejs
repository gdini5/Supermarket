<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Estafeta — Marketplace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  <main class="container">
    <h1 class="page-title">
      <% if (currentName) { %>Olá, <%= currentName.split(' ')[0] %>! 🚴<% } else { %>Dashboard Estafeta<% } %>
    </h1>

    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-icon">📦</span>
        <span class="stat-number"><%= totalDeliveries %></span>
        <span class="stat-label">Entregas realizadas</span>
      </div>
      <div class="stat-card stat-card--warning">
        <span class="stat-icon">🚴</span>
        <span class="stat-number"><%= activeDelivery ? 1 : 0 %></span>
        <span class="stat-label">Entrega ativa</span>
      </div>
      <div class="stat-card">
        <span class="stat-icon">🏪</span>
        <span class="stat-number"><%= availableCount %></span>
        <span class="stat-label">Entregas disponíveis</span>
      </div>
    </div>

    <!-- Entrega ativa -->
    <% if (activeDelivery) { %>
      <div class="card" style="margin-top:1.25rem;border-color:var(--blue)">
        <h3 style="font-family:var(--font-display);font-size:1rem;margin-bottom:1rem;color:var(--cyan)">
          🚴 Entrega em curso
        </h3>
        <div style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:.75rem;margin-bottom:1rem">
          <div>
            <p style="font-size:.75rem;color:var(--text-3);text-transform:uppercase;margin-bottom:.2rem">Supermercado</p>
            <p style="font-weight:600"><%= activeDelivery.supermarketId?.name || '—' %></p>
            <p style="font-size:.78rem;color:var(--text-3)"><%= activeDelivery.supermarketId?.address || '' %></p>
          </div>
          <div>
            <p style="font-size:.75rem;color:var(--text-3);text-transform:uppercase;margin-bottom:.2rem">Cliente</p>
            <p><%= activeDelivery.clientId?.name || '—' %></p>
          </div>
          <div>
            <p style="font-size:.75rem;color:var(--text-3);text-transform:uppercase;margin-bottom:.2rem">Total</p>
            <p style="font-weight:600"><%= activeDelivery.total.toFixed(2) %> €</p>
          </div>
        </div>
        <div style="display:flex;gap:.75rem">
          <form action="/orders/<%= activeDelivery._id %>/status" method="POST">
            <input type="hidden" name="status" value="delivered">
            <button class="btn btn-success">📦 Marcar como entregue</button>
          </form>
          <a href="/orders/<%= activeDelivery._id %>" class="btn btn-secondary">Ver detalhes</a>
        </div>
      </div>
    <% } %>

    <!-- Entregas disponíveis -->
    <div class="card" style="margin-top:1.25rem">
      <h3 style="font-family:var(--font-display);font-size:.9rem;margin-bottom:1rem;color:var(--text-2);text-transform:uppercase;letter-spacing:.05em">
        Entregas disponíveis
      </h3>
      <% if (available.length === 0) { %>
        <p style="color:var(--text-3);font-size:.875rem">Nenhuma entrega disponível de momento.</p>
      <% } else { %>
        <table class="table">
          <thead>
            <tr><th>Supermercado</th><th>Morada</th><th>Cliente</th><th>Total</th><th></th></tr>
          </thead>
          <tbody>
            <% available.forEach(o => { %>
              <tr>
                <td><strong><%= o.supermarketId?.name || '—' %></strong></td>
                <td style="font-size:.82rem;color:var(--text-3)"><%= o.supermarketId?.address || '—' %></td>
                <td><%= o.clientId?.name || '—' %></td>
                <td><strong><%= o.total.toFixed(2) %> €</strong></td>
                <td>
                  <% if (!activeDelivery) { %>
                    <form action="/orders/<%= o._id %>/status" method="POST">
                      <input type="hidden" name="status" value="delivering">
                      <button class="btn btn-primary btn-sm">🚴 Aceitar</button>
                    </form>
                  <% } else { %>
                    <span style="font-size:.78rem;color:var(--text-3)">Termina a atual primeiro</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <!-- Top supermercados -->
    <% if (topSupermarkets.length > 0) { %>
      <div class="card" style="margin-top:1.25rem">
        <h3 style="font-family:var(--font-display);font-size:.9rem;margin-bottom:1rem;color:var(--text-2);text-transform:uppercase;letter-spacing:.05em">
          Supermercados com mais entregas
        </h3>
        <% topSupermarkets.forEach((s, i) => { %>
          <div style="display:flex;justify-content:space-between;align-items:center;padding:.45rem 0;border-bottom:1px solid var(--border)">
            <span style="font-size:.875rem;color:var(--text-2)">
              <span style="color:var(--text-3);margin-right:.4rem"><%= i+1 %>.</span>
              <%= s._id %>
            </span>
            <span class="badge badge--neutral"><%= s.count %> entregas</span>
          </div>
        <% }) %>
      </div>
    <% } %>

  </main>
  <%- include('../partials/footer') %>
</body>
</html>
