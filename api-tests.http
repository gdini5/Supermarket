### SECÇÃO 9 — Admin (controlo de acesso)
### ────────────────────────────────────────────────────────────

# Teste 9.1: Dashboard admin com token de admin
# → Esperado: 200 { totalUsers, activeSupermarkets, totalOrders, pendingSupermarkets }
GET {{baseUrl}}/admin/dashboard
Authorization: Bearer {{adminToken}}

###

# Teste 9.2: ESCALADA — cliente tenta aceder ao dashboard admin
# → Esperado: 403 { error: "Sem permissão para este recurso." }
GET {{baseUrl}}/admin/dashboard
Authorization: Bearer {{clientToken}}

###

# Teste 9.3: ESCALADA — estafeta tenta aceder ao dashboard admin
# → Esperado: 403
GET {{baseUrl}}/admin/dashboard
Authorization: Bearer {{courierToken}}

###

# Teste 9.4: ESCALADA — supermercado tenta aceder ao dashboard admin
# → Esperado: 403
GET {{baseUrl}}/admin/dashboard
Authorization: Bearer {{supermarketToken}}

###

# Teste 9.5: ESCALADA — sem token algum
# → Esperado: 401 { error: "Token em falta ou formato inválido." }
GET {{baseUrl}}/admin/dashboard

###

# Teste 9.6: Admin lista todos os supermercados (aprovados e pendentes)
# → Esperado: 200 array com approved=true e approved=false
GET {{baseUrl}}/admin/supermarkets
Authorization: Bearer {{adminToken}}

###

# Teste 9.7: Admin aprova supermercado
# → Esperado: 200 { ..., approved: true }
PATCH {{baseUrl}}/admin/supermarkets/{{targetSmId}}/approve
Authorization: Bearer {{adminToken}}

###

# Teste 9.8: Admin rejeita supermercado
# → Esperado: 200 { ..., approved: false }
PATCH {{baseUrl}}/admin/supermarkets/{{targetSmId}}/reject
Authorization: Bearer {{adminToken}}

###

# Teste 9.9: Admin lista todos os utilizadores (sem admins)
# → Esperado: 200 array — SEM campo password em nenhum utilizador
GET {{baseUrl}}/admin/users
Authorization: Bearer {{adminToken}}

###

# Teste 9.10: Admin desativa utilizador (toggle active)
# → Esperado: 200 { ..., active: false }
PATCH {{baseUrl}}/admin/users/{{targetUserId}}/toggle
Authorization: Bearer {{adminToken}}

###

# Teste 9.11: Utilizador desativado tenta fazer login
# → PRÉ-CONDIÇÃO: utilizador do teste 9.10 com active=false
# → Esperado: 401 { error: "Esta conta está desativada." }
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "cliente.teste@example.com",
  "password": "senha123"
}

###

# Teste 9.12: Admin reactiva utilizador
# → Esperado: 200 { ..., active: true }
PATCH {{baseUrl}}/admin/users/{{targetUserId}}/toggle
Authorization: Bearer {{adminToken}}

###

# Teste 9.13: Admin lista encomendas (monitorização)
# → Esperado: 200 array de todas as encomendas
GET {{baseUrl}}/admin/orders
Authorization: Bearer {{adminToken}}

###

# Teste 9.14: Admin lista categorias (inclui inactivas)
# → Esperado: 200 array completo
GET {{baseUrl}}/admin/categories
Authorization: Bearer {{adminToken}}

###

