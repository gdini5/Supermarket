### ────────────────────────────────────────────────────────────
### SECÇÃO 10 — Injecção e segurança
### ────────────────────────────────────────────────────────────

# Teste 10.1: NoSQL Injection — operador $gt no email
# → Esperado: 401 ou 400 — NUNCA 200 (com express-mongo-sanitize, $gt é removido)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": { "$gt": "" },
  "password": "qualquercoisa"
}

###

# Teste 10.2: NoSQL Injection — operador $ne na password
# → Esperado: 401 ou 400 — NUNCA 200
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@marketplace.pt",
  "password": { "$ne": null }
}

###

# Teste 10.3: NoSQL Injection — operador $where (código JS)
# → Esperado: 401 ou 400
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": { "$where": "sleep(5000)" },
  "password": "abc"
}

###

# Teste 10.4: NoSQL Injection na query string de produtos
# → Esperado: 200 com resultados normais (sanitização remove o operador)
# → NUNCA expor todos os produtos sem filtro real
GET {{baseUrl}}/products?category[$regex]=.*&category[$options]=i

###

# Teste 10.5: XSS attempt no registo — script tag no nome
# → Esperado: 201 com nome guardado como texto literal
# → Verificar GET /auth/me: nome deve ter os caracteres < > sem executar
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "<script>alert('xss')</script>",
  "email": "xss.test@example.com",
  "password": "senha123",
  "confirm": "senha123",
  "address": "Rua XSS, 1",
  "phone": "911111116",
  "role": "client"
}

###

# Teste 10.6: Verificar que nome XSS foi guardado como texto literal
# → Esperado: 200 { name: "<script>alert('xss')</script>" } — texto, não executado
# → Substituir o token pelo token do utilizador criado em 10.5
GET {{baseUrl}}/auth/me
Authorization: Bearer TOKEN_XSS_AQUI

###

# Teste 10.7: Verificar headers de segurança Helmet
# → Verificar na tab "Headers" da resposta:
#    X-Content-Type-Options: nosniff
#    X-Frame-Options: SAMEORIGIN
#    X-DNS-Prefetch-Control: off
# → Se HTTPS: Strict-Transport-Security presente
GET {{baseUrl}}/health

###

# Teste 10.8: Path traversal na query string
# → Esperado: 200 normal (string é tratada como texto) — NUNCA expor ficheiros
GET {{baseUrl}}/products?search=../../../../etc/passwd

###

# Teste 10.9: HTTP verb tampering — método não definido
# → Esperado: 404 ou 405 — nunca 200
DELETE {{baseUrl}}/auth/login

###

# Teste 10.10: CORS — origem não permitida
# → Simulação: testar via curl de origem diferente:
# curl -H "Origin: http://evil.com" -I http://localhost:3000/api/v1/health
# → Esperado: Access-Control-Allow-Origin NÃO inclui http://evil.com
GET {{baseUrl}}/health

###
